## Repository Pattern

```dart
// features/auth/data/auth_repository.dart
class AuthRepository {
  final AuthService _service;

  AuthRepository(this._service);

  Future<Result<User>> login(String email, String password) async {
    try {
      final response = await _service.login({
        'email': email,
        'password': password,
      });

      if (response.isSuccessful && response.body != null) {
        final dto = standardSerializers.deserializeWith(
          UserResponseDto.serializer,
          response.body,
        );
        return Success(dto!.data.toDomain());
      }

      return Failure(response.error?.toString() ?? 'Login failed');
    } on SocketException {
      return Failure('No internet connection');
    } catch (e) {
      return Failure(e.toString());
    }
  }

  Future<Result<PaginatedList<Notification>>> getNotifications({
    required int page,
    String? read,
  }) async {
    try {
      final response = await _service.getNotifications(
        page: page,
        read: read,
      );

      if (response.isSuccessful && response.body != null) {
        final dto = standardSerializers.deserializeWith(
          NotificationListResponseDto.serializer,
          response.body,
        );
        return Success(PaginatedList(
          items: dto!.data.map((d) => d.toDomain()).toList(),
          currentPage: dto.meta.currentPage,
          lastPage: dto.meta.lastPage,
          perPage: dto.meta.perPage,
          total: dto.meta.total,
        ));
      }

      return Failure(response.error?.toString() ?? 'Failed to load');
    } catch (e) {
      return Failure(e.toString());
    }
  }
}
```

