## Paginated: PaginatedListView

### 1. Create Notifier

**Pattern 2: With direct use case injection**

```dart
class NotificationNotifier extends PaginatedNotifier<Notification> {
  final GetNotificationsUseCase _getNotificationsUseCase;
  final MarkAllAsReadUseCase _markAllAsReadUseCase;

  NotificationNotifier(
    this._getNotificationsUseCase,
    this._markAllAsReadUseCase,
  ) : super();

  @override
  Future<Result<PaginatedList<Notification>>> fetchPage({
    required int page,
    Map<String, dynamic>? params,
  }) async {
    return await _getNotificationsUseCase.execute(
      page: page,
      read: params?['read'] as NotificationReadFilter?,
      includeUnreadCount: params?['includeUnreadCount'] as bool? ?? true,
    );
  }

  // Typed convenience methods
  Future<void> loadNotifications({
    NotificationReadFilter? read,
    bool includeUnreadCount = true,
  }) async {
    return load(params: {
      'read': read,
      'includeUnreadCount': includeUnreadCount,
    });
  }

  Future<void> loadMoreNotifications({
    NotificationReadFilter? read,
    bool includeUnreadCount = true,
  }) async {
    return loadMore(params: {
      'read': read,
      'includeUnreadCount': includeUnreadCount,
    });
  }

  // Additional business logic methods
  Future<void> markAllAsRead() async {
    final result = await _markAllAsReadUseCase.execute();
    switch (result) {
      case Success<void>():
        await loadNotifications(read: NotificationReadFilter.all);
      case Failure<void>(:final message):
        state = PaginatedState.error(message);
    }
  }
}

final notificationProvider = StateNotifierProvider<NotificationNotifier, PaginatedState<Notification>>((ref) {
  final getUseCase = ref.watch(getNotificationsUseCaseProvider);
  final markReadUseCase = ref.watch(markAllAsReadUseCaseProvider);
  return NotificationNotifier(getUseCase, markReadUseCase);
});
```

### 2. Use Widget

```dart
class NotificationsScreen extends ConsumerStatefulWidget {
  @override
  ConsumerState<NotificationsScreen> createState() => _NotificationsScreenState();
}

class _NotificationsScreenState extends ConsumerState<NotificationsScreen> {
  NotificationReadFilter _filter = NotificationReadFilter.all;

  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addPostFrameCallback((_) {
      ref.read(notificationProvider.notifier).loadNotifications(read: _filter);
    });
  }

  @override
  Widget build(BuildContext context) {
    final l10n = AppLocalizations.of(context)!;

    return Scaffold(
      body: PaginatedListView<Notification>(
        state: ref.watch(notificationProvider),
        onRefresh: () => ref.read(notificationProvider.notifier)
            .loadNotifications(read: _filter),
        onLoadMore: () => ref.read(notificationProvider.notifier)
            .loadMoreNotifications(read: _filter),
        itemBuilder: (context, notification, index) => NotificationItem(
          notification: notification,
        ),
        emptyWidget: Center(child: Text(l10n.noNotifications)),
      ),
    );
  }
}
```

